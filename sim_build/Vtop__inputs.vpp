`begin_keywords "1800-2023"
package bus_endpoint;
    typedef enum int {
        TYPE_REG_IN,
        TYPE_REG_OUT,
        TYPE_FIFO_IN,
        TYPE_FIFO_OUT,
        TYPE_SRAM_IN,
        TYPE_SRAM_OUT,
        TYPE_IRQ
    } cell_type_t;
    typedef struct {
        int bit_offset;  
        int bit_width;   
    } field_config_t;
    typedef struct {
        cell_type_t cell_type;           
        int offset;                      
        int size;                        
        int mem_size;                    
        field_config_t cell_config[32];  
    } cell_config_t;
    typedef enum int {
        BUS_AVALON,
        BUS_AXI_LITE,
        BUS_AXI
    } cell_bus_t;
    typedef struct {
        int         bus;
        logic       burst;
        logic       atomic;
        int         data_width;
        int         addr_width;
    } endpoint_config_t;
    localparam DEFAULT_REG_COUNT = 64;
endpackage: bus_endpoint
`begin_keywords "1800-2023"
interface cell_interface #(
    parameter int DATA_WIDTH = 32,
    parameter int ADDR_WIDTH = 32
);
    logic [5:0]                         atop;
    logic                               request;
    logic                               done;
    logic                               error;
    logic [ADDR_WIDTH - 1 : 0]          addr;
    logic [DATA_WIDTH - 1 : 0]          data;
    logic [(DATA_WIDTH / 8) - 1 : 0]    byteen;
    modport fsm_in (
        output  atop,
        output  request,
        output  addr,
        input   data,
        output  byteen,
        input   done,
        input   error
    );
    modport fsm_out (
        output  atop,
        output  request,
        output  addr,
        output  data,
        output  byteen,
        input   done,
        input   error
    );
    modport cells_in (
        input   atop,
        input   request,
        input   addr,
        output  data,
        input   byteen,
        output  done,
        output  error
    );
    modport cells_out (
        input   atop,
        input   request,
        input   addr,
        input   data,
        input   byteen,
        output  done,
        output  error
    );
endinterface: cell_interface
`begin_keywords "1800-2023"
module fifo_in();
endmodule: fifo_in
